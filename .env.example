# Postgres connection — Neon project URL or local Postgres.
# Must point to a Postgres 14+ instance with the `vector` extension available.
DATABASE_URL=postgresql://user:password@host:5432/xsaved_rag

# OpenAI key — for the embeddings API (text-embedding-3-small).
OPENAI_API_KEY=sk-...

# Anthropic key — for the generation API (Claude). Needed by npm run ask.
ANTHROPIC_API_KEY=sk-ant-...

# Path to a bookmarks export JSON. Defaults to the bundled demo corpus in ./data.
BOOKMARKS_PATH=./data/bookmarks.json

# How many bookmarks to index. Step 1 of the learning order uses 100.
INDEX_LIMIT=100

# ── V2: media enrichment ──────────────────────────────────────────────────
# Reposts / cards / articles / links enrich for free from metadata (no model).
# Images / videos are captioned with gpt-5.4-nano — but only when the image
# bytes can be loaded. Set ENRICH_VISION=false to skip captioning entirely.
ENRICH_VISION=true

# Directory holding the local media files referenced by the bookmarks export
# (".../assets/media/<id>_0_0.webp"). Leave unset to skip local files; http(s)
# media URLs are always fetched regardless of this setting.
# MEDIA_ASSETS_DIR=/path/to/assets/media

# Set to true to re-run enrichment on every bookmark (e.g. after pointing
# MEDIA_ASSETS_DIR at real images, or switching caption model). Default: cached.
ENRICH_FORCE=false
